name: Orka Dev Tools Showcase

on:
  workflow_dispatch:

jobs:
  setup-vm:
    runs-on: [self-hosted, orka]
    steps:
      - name: Configure Passwordless Sudo
        run: |
          echo "$(whoami) ALL=(ALL) NOPASSWD: /bin/rm, /usr/bin/pkill, /usr/sbin/screencapture" | sudo tee /etc/sudoers.d/orka-user > /dev/null
          echo "✅ Passwordless sudo configured for required commands"
        # Removed VM_PASSWORD to avoid hardcoding; assumes VM is preconfigured or uses secrets

      - name: Ensure Homebrew is Installed
        run: |
          if ! command -v brew &>/dev/null; then
            echo "Installing Homebrew..."
            NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
            echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> ~/.zprofile
            eval "$(/opt/homebrew/bin/brew shellenv)"
          fi
          brew update
          echo "✅ Homebrew ready (version: $(brew --version))"

      - name: Clean and Install Docker Desktop
        run: |
          sudo -n pkill Docker || true
          sudo -n rm -rf "/Applications/Docker.app"
          brew uninstall --cask docker || true
          brew install --cask docker
          echo "✅ Docker installed (version: $(docker --version 2>/dev/null || echo 'Not running'))"
          open -a Docker
          sleep 10
          if pgrep -x Docker >/dev/null; then
            echo "✅ Docker launched successfully"
          else
            echo "❌ Docker failed to launch"
            exit 1
          fi

      - name: Clean and Install Visual Studio Code
        run: |
          sudo -n pkill "Visual Studio Code" || true
          sudo -n rm -rf "/Applications/Visual Studio Code.app"
          brew uninstall --cask visual-studio-code || true
          brew install --cask visual-studio-code
          echo "✅ VS Code installed (version: $(code --version | head -n1 2>/dev/null || echo 'Not running'))"
          open -a "Visual Studio Code" https://github.com
          sleep 5
          if pgrep -x "Code" >/dev/null; then
            echo "✅ VS Code launched with GitHub"
          else
            echo "❌ VS Code failed to launch"
            exit 1
          fi

      - name: Clean and Install Google Chrome
        run: |
          sudo -n pkill "Google Chrome" || true
          sudo -n rm -rf "/Applications/Google Chrome.app"
          brew uninstall --cask google-chrome || true
          brew install --cask google-chrome
          echo "✅ Chrome installed (version: $(/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --version 2>/dev/null || echo 'Not running'))"
          open -a "Google Chrome" https://www.apple.com
          sleep 5
          if pgrep -x "Google Chrome" >/dev/null; then
            echo "✅ Chrome launched Apple.com"
          else
            echo "❌ Chrome failed to launch"
            exit 1
          fi

      - name: Clean and Install iTerm2
        run: |
          sudo -n pkill iTerm || true
          sudo -n rm -rf "/Applications/iTerm.app"
          brew uninstall --cask iterm2 || true
          brew install --cask iterm2
          echo "✅ iTerm2 installed"
          open -a iTerm
          sleep 5
          if pgrep -x iTerm2 >/dev/null; then
            echo "✅ iTerm2 launched"
          else
            echo "❌ iTerm2 failed to launch"
            exit 1
          fi

      - name: Clean and Install Postman
        run: |
          sudo -n pkill Postman || true
          sudo -n rm -rf "/Applications/Postman.app"
          brew uninstall --cask postman || true
          brew install --cask postman
          echo "✅ Postman installed"
          open -a Postman
          sleep 5
          if pgrep -x Postman >/dev/null; then
            echo "✅ Postman launched"
          else
            echo "❌ Postman failed to launch"
            exit 1
          fi

      - name: Clean and Install Slack
        run: |
          sudo -n pkill Slack || true
          sudo -n rm -rf "/Applications/Slack.app"
          brew uninstall --cask slack || true
          brew install --cask slack
          echo "✅ Slack installed (version: $(/Applications/Slack.app/Contents/MacOS/Slack --version 2>/dev/null || echo 'Not running'))"
          open -a Slack
          sleep 5
          if pgrep -x Slack >/dev/null; then
            echo "✅ Slack launched"
          else
            echo "❌ Slack failed to launch"
            exit 1
          fi

      - name: GUI Test – Take Screenshot
        run: |
          mkdir -p ~/orka-screenshots
          sudo -n screencapture -x ~/orka-screenshots/devtools.png
          echo "📸 Screenshot saved"

      - name: Upload Screenshot Artifact
        uses: actions/upload-artifact@v4
        with:
          name: devtools-screenshot
          path: ~/orka-screenshots/devtools.png
          retention-days: 7
        if: always()

      - name: Show Screenshot File Info
        run: |
          ls -lh ~/orka-screenshots

      - name: Display Installed Software Summary
        run: |
          echo "🎉 Installation Summary 🎉"
          echo "----------------------------------"
          echo "| Software            | Status    |"
          echo "----------------------------------"
          [ -d "/Applications/Docker.app" ] && echo "| Docker Desktop      | Installed |" || echo "| Docker Desktop      | Failed    |"
          [ -d "/Applications/Visual Studio Code.app" ] && echo "| Visual Studio Code  | Installed |" || echo "| Visual Studio Code  | Failed    |"
          [ -d "/Applications/Google Chrome.app" ] && echo "| Google Chrome       | Installed |" || echo "| Google Chrome       | Failed    |"
          [ -d "/Applications/iTerm.app" ] && echo "| iTerm2              | Installed |" || echo "| iTerm2              | Failed    |"
          [ -d "/Applications/Postman.app" ] && echo "| Postman             | Installed |" || echo "| Postman             | Failed    |"
          [ -d "/Applications/Slack.app" ] && echo "| Slack               | Installed |" || echo "| Slack               | Failed    |"
          echo "----------------------------------"
          echo "✅ Installation summary displayed"

      - name: Cleanup Installed Software
        if: always()
        run: |
          sudo -n pkill Docker || true
          [ -d "/Applications/Docker.app" ] && { sudo -n rm -rf "/Applications/Docker.app"; brew uninstall --cask docker || true; echo "🗑️ Docker uninstalled"; }
          [ -d "/Applications/Visual Studio Code.app" ] && { sudo -n pkill "Visual Studio Code" || true; sudo -n rm -rf "/Applications/Visual Studio Code.app"; brew uninstall --cask visual-studio-code || true; echo "🗑️ VS Code uninstalled"; }
          [ -d "/Applications/Google Chrome.app" ] && { sudo -n pkill "Google Chrome" || true; sudo -n rm -rf "/Applications/Google Chrome.app"; brew uninstall --cask google-chrome || true; echo "🗑️ Chrome uninstalled"; }
          [ -d "/Applications/iTerm.app" ] && { sudo -n pkill iTerm || true; sudo -n rm -rf "/Applications/iTerm.app"; brew uninstall --cask iterm2 || true; echo "🗑️ iTerm2 uninstalled"; }
          [ -d "/Applications/Postman.app" ] && { sudo -n pkill Postman || true; sudo -n rm -rf "/Applications/Postman.app"; brew uninstall --cask postman || true; echo "🗑️ Postman uninstalled"; }
          [ -d "/Applications/Slack.app" ] && { sudo -n pkill Slack || true; sudo -n rm -rf "/Applications/Slack.app"; brew uninstall --cask slack || true; echo "🗑️ Slack uninstalled"; }
          sudo -n rm -rf ~/orka-screenshots
          echo "🗑️ Screenshots cleaned"
          brew cleanup
          echo "🗑️ Homebrew cache cleaned"
          sudo -n rm -f /etc/sudoers.d/orka-user
          echo "🗑️ Passwordless sudo configuration removed"
